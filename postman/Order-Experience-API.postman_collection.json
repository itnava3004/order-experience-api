                  "",
                  "pm.test('Response contains status', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('status');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-correlation-id",
                "value": "{{$guid}}",
                "type": "text",
                "description": "Optional correlation ID for request tracing"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/orders/{{orderId}}",
              "host": ["{{baseUrl}}"],
              "path": ["orders", "{{orderId}}"]
            },
            "description": "Retrieves a specific order by its alphanumeric ID.\n\nThe `orderId` path parameter accepts alphanumeric characters and hyphens (e.g., ORD-001)."
          },
          "response": [
            {
              "name": "200 — Success",
              "originalRequest": {
                "method": "GET",
                "url": {
                  "raw": "{{baseUrl}}/orders/ORD-001",
                  "host": ["{{baseUrl}}"],
                  "path": ["orders", "ORD-001"]
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"orderId\": \"ORD-001\",\n  \"customerId\": \"CUST-001\",\n  \"status\": \"PENDING\",\n  \"items\": [\n    {\n      \"productId\": \"PROD-001\",\n      \"quantity\": 2\n    }\n  ],\n  \"shippingAddress\": {\n    \"line1\": \"123 Main St\",\n    \"city\": \"Austin\",\n    \"state\": \"TX\",\n    \"postalCode\": \"78701\",\n    \"country\": \"US\"\n  }\n}"
            },
