      xmlns:munit="http://www.mulesoft.org/schema/mule/munit"
      xmlns:munit-tools="http://www.mulesoft.org/schema/mule/munit-tools"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="
        http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd
        http://www.mulesoft.org/schema/mule/munit http://www.mulesoft.org/schema/mule/munit/current/mule-munit.xsd
        http://www.mulesoft.org/schema/mule/munit-tools http://www.mulesoft.org/schema/mule/munit-tools/current/mule-munit-tools.xsd">

  <munit:config name="order-experience-api-test-suite"/>

  <!-- ================================================================ -->
  <!-- Test 1: GET /orders — sub-flow direct call                       -->
  <!-- Covers: get:\orders:order-experience-api-config (100%)           -->
  <!-- ================================================================ -->
  <munit:test name="get-orders-test" description="Test GET /orders returns 200">
    <munit:behavior>
      <munit-tools:mock-when processor="http:request">
        <munit-tools:with-attributes>
          <munit-tools:with-attribute attributeName="config-ref" whereValue="processApiConfig"/>
        </munit-tools:with-attributes>
        <munit-tools:then-return>
          <munit-tools:payload
            value='#[output application/json --- [{"orderId": "ORD-001", "status": "PENDING"}]]'
            mediaType="application/json"/>
          <munit-tools:attributes value='#[{statusCode: 200}]'/>
        </munit-tools:then-return>
      </munit-tools:mock-when>
    </munit:behavior>
    <munit:execution>
      <set-variable variableName="correlationId" value="test-correlation-id"/>
      <flow-ref name="get:\orders:order-experience-api-config"/>
    </munit:execution>
    <munit:validation>
      <!-- Assert payload is not null and contains expected data -->
      <munit-tools:assert-that expression="#[payload]" is="#[MunitTools::notNullValue()]"/>
      <munit-tools:assert-that expression="#[sizeOf(payload)]" is="#[MunitTools::greaterThanOrEqualTo(1)]"/>
      <munit-tools:assert-that expression="#[payload[0].orderId]" is="#[MunitTools::equalTo('ORD-001')]"/>
      <munit-tools:assert-that expression="#[payload[0].status]" is="#[MunitTools::equalTo('PENDING')]"/>
      <!-- Verify http:request to process API was called exactly once -->
      <munit-tools:verify-call processor="http:request" times="1">
        <munit-tools:with-attributes>
          <munit-tools:with-attribute attributeName="config-ref" whereValue="processApiConfig"/>
        </munit-tools:with-attributes>
      </munit-tools:verify-call>
    </munit:validation>
  </munit:test>

  <!-- ================================================================ -->
  <!-- Test 2: POST /orders — sub-flow direct call                      -->
  <!-- Covers: post:\orders:order-experience-api-config (100%)          -->
  <!-- ================================================================ -->
  <munit:test name="create-order-test" description="Test POST /orders returns 201">
    <munit:behavior>
      <munit-tools:mock-when processor="http:request">
        <munit-tools:with-attributes>
          <munit-tools:with-attribute attributeName="config-ref" whereValue="processApiConfig"/>
        </munit-tools:with-attributes>
        <munit-tools:then-return>
          <munit-tools:payload
            value='#[output application/json --- {"orderId": "ORD-002", "status": "CREATED"}]'
            mediaType="application/json"/>
          <munit-tools:attributes value='#[{statusCode: 201}]'/>
        </munit-tools:then-return>
      </munit-tools:mock-when>
    </munit:behavior>
    <munit:execution>
      <set-variable variableName="correlationId" value="test-correlation-id"/>
      <set-payload
        value='#[output application/json --- {"customerId": "CUST-001", "items": [{"productId": "PROD-001", "quantity": 1}], "shippingAddress": {"line1": "123 Main St", "city": "Austin", "state": "TX", "postalCode": "78701", "country": "US"}}]'
        mimeType="application/json"/>
      <flow-ref name="post:\orders:order-experience-api-config"/>
    </munit:execution>
    <munit:validation>
      <!-- Assert httpStatus is set to 201 (String) -->
      <munit-tools:assert-that expression="#[vars.httpStatus]" is="#[MunitTools::equalTo('201')]"/>
      <!-- Assert payload contains expected order data -->
      <munit-tools:assert-that expression="#[payload]" is="#[MunitTools::notNullValue()]"/>
      <munit-tools:assert-that expression="#[payload.orderId]" is="#[MunitTools::equalTo('ORD-002')]"/>
      <munit-tools:assert-that expression="#[payload.status]" is="#[MunitTools::equalTo('CREATED')]"/>
      <!-- Verify http:request to process API was called exactly once -->
      <munit-tools:verify-call processor="http:request" times="1">
        <munit-tools:with-attributes>
          <munit-tools:with-attribute attributeName="config-ref" whereValue="processApiConfig"/>
        </munit-tools:with-attributes>
      </munit-tools:verify-call>
    </munit:validation>
  </munit:test>

